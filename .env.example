EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com/
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_AUTH_EMAIL_DOMAIN=purr.ivacy
EXPO_PUBLIC_DEV_TEMP_KEY_COUNT=0

EXPO_PUBLIC_UPDATE_GITHUB_REPO_URL=https://github.com/owner/repo
# Do not ship a PAT in public production builds. EXPO_PUBLIC values are bundled into the app.
EXPO_PUBLIC_UPDATE_GITHUB_TOKEN=

# Sentry DSN is public client config. Runtime Sentry environment uses APP_ENV.
# SENTRY_AUTH_TOKEN, SENTRY_ORG, and SENTRY_PROJECT are build secrets.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENABLED=true
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional Android debug identity. Set these in .env.development when you want
# a side-by-side dev install; the google services file must contain the .dev
# package if you use the suffix.
EXPO_ANDROID_DEBUG_APPLICATION_ID_SUFFIX=
EXPO_ANDROID_DEBUG_VERSION_NAME_SUFFIX=
EXPO_ANDROID_GOOGLE_SERVICES_FILE=

SENTRY_ORG=
SENTRY_PROJECT=purrivacyapp
SENTRY_AUTH_TOKEN=
# Use this only for builds where source-map upload is intentionally disabled.
SENTRY_DISABLE_AUTO_UPLOAD=
