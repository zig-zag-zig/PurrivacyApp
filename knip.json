{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "entry": [
        "App.tsx",
        "index.js",
        "index.ts",
        "scripts/android-autofill-highlight.js",
        "scripts/android-build-variants.js",
        "scripts/android-e2e-cleartext.js",
        "scripts/android-local-build.cjs",
        "scripts/android-system-bars.js",
        "scripts/android-update-installer.js",
        "scripts/configure-android-gradle.cjs",
        "scripts/native-security.js",
        "scripts/normalize-android-gradle-warnings.cjs",
        "scripts/patch-openpgp.js",
        "scripts/run-local-android-e2e.cjs",
        "scripts/run-local-maestro-e2e.cjs",
        "scripts/run-maestro.cjs",
        "scripts/sync-android-version.cjs"
    ],
    "ignoreDependencies": [
        "buffer",
        "expo-updates"
    ],
    "ignore": [
        "android/**",
        "ios/**",
        "node_modules/**",
        "**/__tests__/**",
        "**/*.test.{js,ts,tsx}",
        "**/*.spec.{js,ts,tsx}",
        "**/*.mock.{js,ts,tsx}",
        "metro.config.js",
        "*.config.js"
    ]
}
